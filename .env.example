# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Blog reading font — must match a font imported in frontend/src/app/layout.tsx
NEXT_PUBLIC_BLOG_FONT=Source_Serif_4

# Backend
APP_ENV=dev
FRONTEND_ORIGIN=http://localhost:3000

# Public MCP server host allow-list (fastmcp >= 3.4.3 rejects any Host not in
# this list with 421 "Misdirected Request" — DNS-rebinding protection). The
# defaults 127.0.0.1/localhost/::1 are always allowed, so this is only needed
# for the public domain in production. JSON array; supports fnmatch wildcards.
# PROD: FASTMCP_HTTP_ALLOWED_HOSTS=["api.jayaremala.com"]
# FASTMCP_HTTP_ALLOWED_HOSTS=

# Google AI
GOOGLE_API_KEY=
# Primary model — falls back through GEMINI_FALLBACK_MODELS on 503/429
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-flash-latest

# Persistent analytics DB — on Railway set to absolute path on persistent volume
# e.g. ANALYTICS_DB_PATH=/data/analytics.db
ANALYTICS_DB_PATH=./chroma_db/analytics.db
